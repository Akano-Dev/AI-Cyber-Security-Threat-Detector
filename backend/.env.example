# Copy to .env and adjust. ACSTD backend configuration.

# The real website ACSTD should protect (proxy target). Leave blank to disable proxying.
TARGET_URL=http://localhost:8090

# Rate limiting: auto-block an IP that sends more than RATE_LIMIT requests within RATE_WINDOW seconds.
RATE_LIMIT=20
RATE_WINDOW=60

# Admin API key — required by mutating endpoints. CHANGE THIS in production.
API_KEY=change-me

# Number of trusted reverse proxies in front of the app (real client IP via X-Forwarded-For).
TRUSTED_PROXY_COUNT=0

# Max request body size in bytes.
MAX_BODY_BYTES=1000000
